pipeline {
    agent any

    tools {
        nodejs 'NodeJS'
    }

    environment {
        DOCKERHUB_USERNAME = 'yoselrai'
        IMAGE_NAME = "${DOCKERHUB_USERNAME}/todo-backend"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    credentialsId: 'github-pat',
                    url: 'https://github.com/RUMX69/YoselRai_02250381_DSO101_A1.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('todo-app/backend') {
                    bat 'npm install'
                }
            }
        }

        stage('Build') {
            steps {
                dir('todo-app/backend') {
                    bat 'npm run build'
                }
            }
        }

        stage('Test') {
            steps {
                dir('todo-app/backend') {
                    bat 'npm test'
                }
            }
            post {
                always {
                    junit 'todo-app/backend/junit.xml'
                }
            }
        }

        stage('Deploy - Docker') {
            steps {
                dir('todo-app/backend') {
                    script {
                        def image = docker.build("${IMAGE_NAME}:latest")
                        docker.withRegistry('https://registry.hub.docker.com', 'docker-hub-creds') {
                            image.push()
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed. Check the logs above.'
        }
    }
}